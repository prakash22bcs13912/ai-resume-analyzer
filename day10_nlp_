import re
import spacy
import pandas as pd
import matplotlib.pyplot as plt
from collections import Counter
# ── Load spaCy model ──────────────────────────────────────────
nlp = spacy.load("en_core_web_sm")
print("✅ spaCy loaded:", spacy.__version__)
# =============================================================
# SAMPLE RESUMES (replace with your real data later)
# =============================================================
resume_1 = """
