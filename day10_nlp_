"""
resumes = [
    {"id": 1, "name": "John Doe",     "text": resume_1},
    {"id": 2, "name": "Priya Sharma", "text": resume_2},
]
# =============================================================
# EXTRACTOR 1 — Named Entity Recognition (spaCy)
# =============================================================
def extract_named_entities(text):
    doc = nlp(text)
    entities = {"PERSON": [], "ORG": [], "DATE": [], "GPE": []}
    for ent in doc.ents:
        if ent.label_ in entities:
            clean = ent.text.strip()
            if clean and clean not in entities[ent.label_]:
                entities[ent.label_].append(clean)
    return entities
# =============================================================
# EXTRACTOR 2 — Skill Keyword Matching
# =============================================================
SKILLS_DB = sorted([
    # Programming
    "python", "java", "javascript", "c++", "c#", "r", "scala", "typescript",
    # Data / ML
    "machine learning", "deep learning", "nlp", "natural language processing",
    "data science", "data analysis", "scikit-learn", "tensorflow", "keras",
    "pytorch", "xgboost", "pandas", "numpy", "matplotlib", "seaborn", "plotly",
    # Databases
    "sql", "mysql", "postgresql", "mongodb", "sqlite", "redis",
    # Web
    "html", "css", "react", "node.js", "express.js", "django", "flask",
    "rest api", "rest apis", "graphql", "tailwind css", "bootstrap",
    # Cloud / DevOps
    "aws", "azure", "gcp", "docker", "kubernetes", "git", "ci/cd", "linux",
    # Tools
    "tableau", "power bi", "excel", "postman", "figma", "firebase", "agile",
], key=len, reverse=True)
def extract_skills(text):
    text_lower = text.lower()
    found = []
    for skill in SKILLS_DB:
        pattern = r'\b' + re.escape(skill) + r'\b'
        if re.search(pattern, text_lower):
            found.append(skill)
    return sorted(set(found))
# =============================================================
# EXTRACTOR 3 — Education
# =============================================================
DEGREE_REGEX = re.compile(
    r"B\.?Tech|M\.?Tech|B\.?E\.?|M\.?E\.?|B\.?Sc\.?|M\.?Sc\.?"
    r"|Bachelor[s]? of [A-Za-z ]+|Master[s]? of [A-Za-z ]+"
    r"|Ph\.?D\.?|MBA|BBA|MCA|BCA",
    re.IGNORECASE
)
def extract_education(text):
    education = []
    for line in text.split("\n"):
        line = line.strip()
        if DEGREE_REGEX.search(line) and len(line) > 5:
            education.append(line)
    return education
# =============================================================
# EXTRACTOR 4 — Years of Experience
# =============================================================
def extract_experience_years(text):
    explicit = re.findall(
        r'(\d+\.?\d*)\s+(?:year[s]?|yr[s]?)\s+of\s+experience',
        text, re.IGNORECASE
    )
    if explicit:
        return float(explicit[0])
    ranges = re.findall(r'(\d{4})\s*[–\-]\s*(\d{4})', text)
    if ranges:
        return sum(int(e) - int(s) for s, e in ranges)
    return 0
# =============================================================
# EXTRACTOR 5 — Contact Info
# =============================================================
def extract_contact_info(text):
    emails = re.findall(r'[\w.+-]+@[\w-]+\.[\w.]+', text)
    phones = re.findall(r'(?:\+91[\-\s]?)?[6-9]\d{9}', text)
    return {
        "email": emails[0] if emails else None,
        "phone": phones[0] if phones else None,
    }
# =============================================================
# FULL PIPELINE
# =============================================================
def process_resume(r):
    text    = r["text"]
    contact = extract_contact_info(text)
    skills  = extract_skills(text)
    edu     = extract_education(text)
    yrs     = extract_experience_years(text)
    ents    = extract_named_entities(text)
    return {
        "id"              : r["id"],
        "name"            : r["name"],
        "email"           : contact["email"],
        "phone"           : contact["phone"],
        "skills"          : ", ".join(skills),
        "skill_count"     : len(skills),
        "education"       : " | ".join(edu),
        "experience_years": yrs,
        "orgs_mentioned"  : ", ".join(ents["ORG"]),
        "locations"       : ", ".join(ents["GPE"]),
    }
print("\n🔄 Running pipeline on all resumes...\n")
results = [process_resume(r) for r in resumes]
df = pd.DataFrame(results)
print(df.to_string(index=False))
# =============================================================
# SKILL FREQUENCY CHART
# =============================================================
all_skills = []
for r in resumes:
    all_skills.extend(extract_skills(r["text"]))
skill_counts = Counter(all_skills).most_common(20)
skills_df = pd.DataFrame(skill_counts, columns=["Skill", "Count"])
plt.figure(figsize=(10, 5))
plt.barh(skills_df["Skill"][::-1], skills_df["Count"][::-1], color="steelblue")
plt.xlabel("Frequency across resumes")
plt.title("Day 10 — Top Skills Frequency")
plt.tight_layout()
plt.savefig("day10_skill_frequency.png", dpi=150)
plt.show()
print("\n✅ Chart saved: day10_skill_frequency.png")
