# =============================================================
# HELPER FUNCTIONS
# =============================================================

def extract_skills(text):
    text_lower = text.lower()
    found = []
    for skill in SKILLS_DB:
        pattern = r'\b' + re.escape(skill) + r'\b'
        if re.search(pattern, text_lower):
            found.append(skill)
    return sorted(set(found))


def get_missing_skills(resume_text, job_description):
    """Find skills in JD that are missing from resume."""
    jd_skills     = set(extract_skills(job_description))
    resume_skills = set(extract_skills(resume_text))
    matched = jd_skills & resume_skills
    missing = jd_skills - resume_skills
    return sorted(matched), sorted(missing)


def get_course_recommendations(missing_skills):
    """
    For each missing skill, find the best course recommendation.
    Returns list of dicts with skill, course name, and URL.
    """
    recommendations = []
    for skill in missing_skills:
        if skill in COURSE_DB:
            course_name, url = COURSE_DB[skill]
            recommendations.append({
                "skill"      : skill,
                "course"     : course_name,
                "url"        : url,
                "platform"   : "Coursera" if "coursera" in url
                          else "YouTube"  if "youtube" in url
                          else "Kaggle"   if "kaggle"  in url
                          else "Official",
                "free"       : "✅ Free" if any(x in url for x in
                               ["youtube", "kaggle", "numpy", "microsoft", "aws"])
                          else "💳 Paid (audit free)",
            })
        else:
            recommendations.append({
                "skill"   : skill,
                "course"  : f"Search '{skill} tutorial' on YouTube",
                "url"     : f"https://www.youtube.com/results?search_query={skill}+tutorial",
                "platform": "YouTube",
                "free"    : "✅ Free",
            })
    return recommendations


def generate_resume_tips(resume_text, job_description, final_score):
    """Generate actionable tips based on score."""
    tips = []

    if final_score < 50:
        tips.append("📝 Rewrite your resume summary to match the job title exactly.")
        tips.append("🔑 Add a dedicated 'Skills' section with keywords from the job description.")
        tips.append("📊 Quantify your achievements — e.g. 'Improved accuracy by 15%'.")

    elif final_score < 70:
        tips.append("✨ Add the missing skills to your resume after learning them.")
        tips.append("📋 Mirror the exact keywords from the job description.")
        tips.append("💼 Add more details to your experience section.")

    else:
        tips.append("🎯 Your resume is strong! Customize the summary for this role.")
        tips.append("🌟 Highlight your most relevant projects at the top.")
        tips.append("🤝 Make sure your LinkedIn matches your resume.")

    # Word count tip
    word_count = len(resume_text.split())
    if word_count < 200:
        tips.append("📄 Your resume seems short. Add more details about your experience.")
    elif word_count > 800:
        tips.append("✂️ Your resume might be too long. Try to keep it to 1-2 pages.")

    return tips


def full_recommendation_report(resume_text, job_description, candidate_name="Candidate"):
    """Run the full recommendation pipeline."""

    # Score
    vectorizer  = TfidfVectorizer(stop_words="english")
    tfidf       = vectorizer.fit_transform([job_description, resume_text])
    tfidf_score = cosine_similarity(tfidf[0:1], tfidf[1:2])[0][0] * 100

    jd_skills     = set(extract_skills(job_description))
    resume_skills = set(extract_skills(resume_text))
    matched       = sorted(jd_skills & resume_skills)
    missing       = sorted(jd_skills - resume_skills)
    skill_score   = (len(matched) / len(jd_skills) * 100) if jd_skills else 0
    final_score   = round((tfidf_score * 0.5) + (skill_score * 0.5), 1)

    grade = (
        "🟢 Excellent" if final_score >= 70 else
        "🟡 Good"      if final_score >= 50 else
        "🔴 Needs Work"
    )

    # Courses
    courses = get_course_recommendations(missing)

    # Tips
    tips = generate_resume_tips(resume_text, job_description, final_score)

    return {
        "candidate"   : candidate_name,
        "final_score" : final_score,
        "grade"       : grade,
        "matched"     : matched,
        "missing"     : missing,
        "courses"     : courses,
        "tips"        : tips,
    }


